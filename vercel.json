{
  "framework": "nextjs",
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install --frozen-lockfile",
  "regions": ["icn1"],
  "functions": {
    "src/app/api/parse/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/cron/flush-pending-image-groups/route.ts": {
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/cron/flush-pending-image-groups",
      "schedule": "* * * * *"
    }
  ]
}
